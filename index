          </div>
          <div style="display:flex;align-items:center;gap:12px;padding:12px 16px;background:var(--surface);border:0.5px solid var(--border);border-radius:var(--radius)">
            <div style="width:8px;height:8px;border-radius:50%;background:var(--norma);flex-shrink:0"></div>
            <p style="font-size:13px;color:var(--text2)">Diseñada nativamente para normas ISO</p>
          </div>
