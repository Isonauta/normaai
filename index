<style>
  :root {
    --dark: #1A1916; --dark2: #1e1b2e;
    --bg: #F7F6F2; --surface: #FFFFFF; --surface2: #F0EEE8;
    --border: rgba(0,0,0,0.10); --border2: rgba(0,0,0,0.18);
    --text: #1A1916; --text2: #6B6A64; --text3: #9C9A92;
    --ocre: #C9922A; --ocre-light: #F5E6C8;
    --norma: #8B2FC9; --norma-light: #F3E8FC; --norma-dark: #6B1FA9;
    --norma-glow: rgba(139,47,201,0.15);
    --radius: 10px; --radius-lg: 16px;
    --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 4px 16px rgba(0,0,0,0.04);
    --shadow-lg: 0 8px 40px rgba(0,0,0,0.12);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); overflow-x: hidden; }

  /* Nav */
  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(26,25,22,0.96); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(139,47,201,0.2); padding: 0 24px; }
  .nav-inner { max-width: 1080px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; padding: 14px 0; }
  .nav-brand { display: flex; align-items: center; gap: 10px; text-decoration: none; }
  .nav-logo { width: 28px; height: 28px; }
  .nav-name { font-size: 17px; font-weight: 600; color: #fff; letter-spacing: -0.3px; }
  .nav-name span { color: var(--norma); }
  .nav-isonauta { font-size: 11px; color: rgba(255,255,255,0.3); font-family: 'DM Mono', monospace; }
  .nav-back { font-size: 12px; color: rgba(255,255,255,0.4); text-decoration: none; transition: color .15s; }
  .nav-back:hover { color: rgba(255,255,255,0.8); }
  .nav-cta { font-size: 12px; font-weight: 500; padding: 7px 16px; border: 0.5px solid rgba(139,47,201,0.5); border-radius: 20px; color: var(--norma); text-decoration: none; transition: all .15s; background: rgba(139,47,201,0.08); }
  .nav-cta:hover { background: rgba(139,47,201,0.18); }

  /* Hero */
  .hero { min-height: 100vh; background: var(--dark); display: flex; flex-direction: column; justify-content: center; padding: 120px 24px 80px; position: relative; overflow: hidden; }
  .hero::before { content: ''; position: absolute; top: -100px; right: -100px; width: 500px; height: 500px; border-radius: 50%; background: radial-gradient(circle, rgba(139,47,201,0.12) 0%, transparent 70%); pointer-events: none; }
  .hero::after { content: ''; position: absolute; bottom: -100px; left: 200px; width: 400px; height: 400px; border-radius: 50%; background: radial-gradient(circle, rgba(201,146,42,0.05) 0%, transparent 70%); pointer-events: none; }
  .hero-inner { max-width: 1080px; margin: 0 auto; position: relative; z-index: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
  @media (max-width:768px) { .hero-inner { grid-template-columns: 1fr; gap: 40px; } }

  .hero-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(139,47,201,0.12); border: 0.5px solid rgba(139,47,201,0.3); border-radius: 20px; padding: 5px 14px; margin-bottom: 24px; }
  .hero-badge span { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--norma); text-transform: uppercase; letter-spacing: 0.1em; }
  .hero-badge .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--norma); animation: pulse 2s ease infinite; }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.6;transform:scale(0.8)} }

  .hero-title { font-size: clamp(36px, 5vw, 64px); font-weight: 600; letter-spacing: -1.5px; color: #F7F6F2; line-height: 1.05; margin-bottom: 10px; }
  .hero-title em { font-family: 'Playfair Display', serif; font-style: italic; font-weight: 400; color: var(--norma); }
  .hero-sub { font-size: 16px; color: rgba(247,246,242,0.35); font-weight: 300; line-height: 1.7; margin-bottom: 12px; }
  .hero-tagline { font-size: 14px; color: rgba(139,47,201,0.7); font-family: 'DM Mono', monospace; margin-bottom: 36px; letter-spacing: 0.03em; }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }
  .btn-norma { font-size: 13px; font-weight: 500; padding: 12px 28px; background: var(--norma); border: none; border-radius: 24px; color: #fff; cursor: pointer; text-decoration: none; transition: opacity .15s; }
  .btn-norma:hover { opacity: 0.85; }
  .btn-ghost { font-size: 13px; padding: 12px 28px; background: transparent; border: 0.5px solid rgba(255,255,255,0.18); border-radius: 24px; color: rgba(255,255,255,0.55); cursor: pointer; text-decoration: none; transition: all .15s; }
  .btn-ghost:hover { border-color: rgba(255,255,255,0.35); color: rgba(255,255,255,0.8); }

  /* Mockup chat hero */
  .hero-mockup { background: #fff; border-radius: var(--radius-lg); overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(139,47,201,0.2); }
  .mockup-header { background: #f8f7ff; border-bottom: 1px solid rgba(139,47,201,0.1); padding: 12px 16px; display: flex; align-items: center; gap: 10px; }
  .mockup-logo { font-size: 14px; font-weight: 600; color: var(--norma); display: flex; align-items: center; gap: 6px; }
  .mockup-logo svg { width: 18px; height: 18px; }
  .mockup-body { padding: 16px; display: flex; flex-direction: column; gap: 12px; }
  .mockup-msg { font-size: 12px; line-height: 1.55; }
  .mockup-msg.user { background: #f0f0f0; border-radius: 10px 10px 2px 10px; padding: 10px 12px; color: #333; align-self: flex-end; max-width: 85%; }
  .mockup-msg.norma { background: #f8f4ff; border: 0.5px solid rgba(139,47,201,0.15); border-radius: 2px 10px 10px 10px; padding: 10px 12px; color: #333; max-width: 90%; }
  .mockup-msg.norma::before { content: ''; display: block; width: 6px; height: 6px; border-radius: 50%; background: var(--norma); margin-bottom: 6px; }
  .mockup-chips { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 4px; }
  .mockup-chip { font-size: 10px; padding: 4px 10px; border: 0.5px solid rgba(139,47,201,0.3); border-radius: 12px; color: var(--norma); background: rgba(139,47,201,0.05); }
  .mockup-input { margin: 8px 16px 16px; border: 0.5px solid rgba(139,47,201,0.2); border-radius: 20px; padding: 8px 14px; font-size: 11px; color: #999; background: #fafafa; }

  /* Problema */
  .problema { background: var(--dark2); padding: 80px 24px; border-top: 1px solid rgba(139,47,201,0.1); border-bottom: 1px solid rgba(139,47,201,0.1); }
  .problema-inner { max-width: 1080px; margin: 0 auto; }
  .section-eyebrow { font-family: 'DM Mono', monospace; font-size: 10px; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 14px; }
  .section-eyebrow.norma { color: rgba(139,47,201,0.7); }
  .section-titulo { font-size: clamp(26px,3.5vw,42px); font-weight: 600; letter-spacing: -0.8px; margin-bottom: 16px; line-height: 1.15; }
  .section-titulo.light { color: #F7F6F2; }
  .section-titulo em { font-family: 'Playfair Display', serif; font-style: italic; font-weight: 400; }
  .section-titulo.light em { color: var(--norma); }
  .section-desc { font-size: 15px; line-height: 1.7; max-width: 560px; margin-bottom: 40px; }
  .section-desc.light { color: rgba(247,246,242,0.38); }

  .problema-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
  @media (max-width:700px) { .problema-grid { grid-template-columns: 1fr; } }

  /* Mensajes WhatsApp simulados */
  .wa-msgs { display: flex; flex-direction: column; gap: 10px; }
  .wa-msg { background: rgba(255,255,255,0.04); border: 0.5px solid rgba(255,255,255,0.08); border-radius: 4px 12px 12px 12px; padding: 12px 16px; font-size: 13px; color: rgba(247,246,242,0.5); line-height: 1.6; font-style: italic; position: relative; }
  .wa-msg::before { content: ''; position: absolute; left: -1px; top: 0; width: 3px; height: 100%; background: rgba(139,47,201,0.4); border-radius: 2px 0 0 2px; }
  .wa-problema { margin-top: 24px; padding: 20px; background: rgba(139,47,201,0.06); border: 0.5px solid rgba(139,47,201,0.15); border-radius: var(--radius-lg); }
  .wa-problema p { font-size: 15px; color: rgba(247,246,242,0.7); line-height: 1.65; font-weight: 500; }
  .wa-problema em { color: var(--norma); font-style: normal; }

  /* Solución */
  .seccion { padding: 80px 24px; }
  .seccion.alt { background: var(--surface2); }
  .seccion-inner { max-width: 1080px; margin: 0 auto; }

  .solucion-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; margin-top: 40px; }
  @media (max-width:700px) { .solucion-grid { grid-template-columns: 1fr; } }
  .sol-card { background: var(--surface); border: 0.5px solid var(--border); border-radius: var(--radius-lg); padding: 28px 24px; box-shadow: var(--shadow); transition: border-color .2s; }
  .sol-card:hover { border-color: rgba(139,47,201,0.3); }
  .sol-num { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--norma); margin-bottom: 14px; opacity: 0.7; }
  .sol-titulo { font-size: 17px; font-weight: 600; color: var(--text); margin-bottom: 10px; letter-spacing: -0.2px; }
  .sol-desc { font-size: 13px; color: var(--text2); line-height: 1.65; }

  /* Cuadrante posicionamiento */
  .cuadrante-wrap { margin-top: 40px; }
  .cuadrante { position: relative; width: 100%; max-width: 560px; aspect-ratio: 1; border: 0.5px solid var(--border2); border-radius: var(--radius-lg); background: var(--surface); overflow: hidden; }
  .cuadrante-eje-x { position: absolute; bottom: 50%; left: 0; right: 0; height: 0.5px; background: var(--border2); }
  .cuadrante-eje-y { position: absolute; left: 50%; top: 0; bottom: 0; width: 0.5px; background: var(--border2); }
  .cuadrante-label { position: absolute; font-size: 10px; font-family: 'DM Mono', monospace; color: var(--text3); text-transform: uppercase; letter-spacing: 0.05em; }
  .cuadrante-item { position: absolute; transform: translate(-50%,-50%); text-align: center; }
  .cuadrante-dot { width: 10px; height: 10px; border-radius: 50%; margin: 0 auto 5px; }
  .cuadrante-item-label { font-size: 11px; color: var(--text2); white-space: nowrap; font-family: 'DM Mono', monospace; }
  .cuadrante-norma { position: absolute; transform: translate(-50%,-50%); text-align: center; }
  .cuadrante-norma-dot { width: 20px; height: 20px; border-radius: 50%; background: var(--norma); margin: 0 auto 6px; box-shadow: 0 0 16px rgba(139,47,201,0.5); }
  .cuadrante-norma-label { font-size: 13px; font-weight: 600; color: var(--norma); white-space: nowrap; }

  /* Capacidades */
  .caps-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px,1fr)); gap: 14px; margin-top: 40px; }
  .cap-card { background: var(--surface); border: 0.5px solid var(--border); border-radius: var(--radius-lg); padding: 22px 20px; box-shadow: var(--shadow); }
  .cap-icon { width: 36px; height: 36px; border-radius: 8px; background: var(--norma-light); display: flex; align-items: center; justify-content: center; margin-bottom: 14px; }
  .cap-titulo { font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 6px; }
  .cap-desc { font-size: 12px; color: var(--text2); line-height: 1.6; }

  /* Proceso */
  .proceso-steps { display: grid; grid-template-columns: repeat(4,1fr); gap: 0; margin-top: 40px; position: relative; }
  @media (max-width:700px) { .proceso-steps { grid-template-columns: 1fr 1fr; gap: 16px; } }
  .proceso-steps::before { content: ''; position: absolute; top: 24px; left: 12.5%; right: 12.5%; height: 1px; background: linear-gradient(to right, transparent, rgba(139,47,201,0.3), transparent); }
  @media (max-width:700px) { .proceso-steps::before { display: none; } }
  .paso { text-align: center; padding: 0 12px; }
  .paso-num { width: 48px; height: 48px; border-radius: 50%; background: var(--norma-light); border: 2px solid rgba(139,47,201,0.2); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; font-size: 16px; font-weight: 600; color: var(--norma); }
  .paso-titulo { font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 8px; }
  .paso-desc { font-size: 12px; color: var(--text2); line-height: 1.6; }

  /* CTA */
  .cta-final { background: var(--dark); padding: 80px 24px; text-align: center; position: relative; overflow: hidden; }
  .cta-final::before { content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 600px; height: 300px; background: radial-gradient(ellipse, rgba(139,47,201,0.12) 0%, transparent 70%); pointer-events: none; }
  .cta-final-inner { max-width: 600px; margin: 0 auto; position: relative; z-index: 1; }
  .cta-titulo { font-size: clamp(28px,4vw,44px); font-weight: 600; color: #F7F6F2; letter-spacing: -1px; margin-bottom: 12px; line-height: 1.1; }
  .cta-titulo em { font-family: 'Playfair Display', serif; font-style: italic; font-weight: 400; color: var(--norma); }
  .cta-desc { font-size: 14px; color: rgba(247,246,242,0.3); margin-bottom: 32px; line-height: 1.7; }
  .cta-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .cta-nota { font-size: 11px; color: rgba(255,255,255,0.2); font-family: 'DM Mono', monospace; margin-top: 16px; }

  /* Footer */
  .footer { background: #111110; padding: 20px 24px; border-top: 1px solid rgba(139,47,201,0.08); }
  .footer-inner { max-width: 1080px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
  .footer-brand { font-size: 12px; color: var(--ocre); font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; }
  .footer-copy { font-size: 11px; color: rgba(255,255,255,0.15); font-family: 'DM Mono', monospace; }

  /* WhatsApp flotante */
  .wa-btn { position: fixed; bottom: 28px; right: 28px; z-index: 200; width: 52px; height: 52px; border-radius: 50%; background: #25D366; box-shadow: 0 4px 16px rgba(37,211,102,0.4); display: flex; align-items: center; justify-content: center; text-decoration: none; opacity: 0; transform: translateY(16px); transition: opacity .3s, transform .3s; pointer-events: none; }
  .wa-btn.visible { opacity: 1; transform: translateY(0); pointer-events: all; }
  .wa-btn:hover { box-shadow: 0 6px 24px rgba(37,211,102,0.55); }
</style>
</head>
